# ---- Google OAuth client (Web application, from Google Cloud Console) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI on the OAuth client:
GOOGLE_REDIRECT_URI=https://gauth.dev-coolify.tailfa2e0b.ts.net/api/auth/callback

# Public/base URL the app uses to build redirects (tailnet serve URL)
APP_BASE_URL=https://gauth.dev-coolify.tailfa2e0b.ts.net

# ---- /api/token shared secret (n8n HTTP-node flows) ----
TOKEN_API_SECRET=change-me-long-random

# ---- Optional: push active token into an n8n credential ----
# n8n REST API base (note the /api/v1)
N8N_API_URL=http://10.10.2.12:5678/api/v1
N8N_API_KEY=
# id of an existing "Google OAuth2 API" credential in n8n to overwrite on each switch
N8N_CRED_ID=
N8N_CRED_TYPE=googleOAuth2Api

# ---- Token store (Docker volume) ----
TOKEN_STORE_PATH=/data/active-account.json
